{
  "id": "tpl-sa-tsp",
  "displayName": "Simulated Annealing on TSP",
  "runRequest": {
    "searchSpaceId": ["permutation"],
    "searchSpaceParams": {},

    "problemId": ["tsp"],
    "problemParams": {},

    "generatorId": ["2opt"],
    "generatorParams": {},

    "selectionRuleId": ["simulated-annealing"],
    "selectionRuleParams": {
      "startTemp": 1000.0,
      "alpha": 0.999
    },

    "populationModelId": ["default"],
    "populationModelParams": {
      "lambda": 1
    },

    "stopConditionId": ["max-iterations"],
    "stopConditionParams": {
      "maxIterations": 10000
    },

    "observerIds": ["fitness", "fitness-phase","acceptance-rate", "improvements","tsp-tour"],

    "seed": 1,
    "runTimes": 10
  }
}